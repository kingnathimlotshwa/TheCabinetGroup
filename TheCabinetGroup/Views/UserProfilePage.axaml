<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="TheCabinetGroup.Views.UserProfilePage"
    x:DataType="vm:UserProfileViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:conv="clr-namespace:TheCabinetGroup.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shadUi="clr-namespace:ShadUI;assembly=ShadUI"
    xmlns:vm="clr-namespace:TheCabinetGroup.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <vm:UserProfileViewModel />
    </Design.DataContext>
    <Panel>
        <ScrollViewer
            HorizontalAlignment="Center"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,12" Spacing="16">

                <!--  ── Section switcher (Details / Security) ────────────────────  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <ToggleButton
                        Classes="Outline"
                        Command="{Binding ShowDetailsCommand}"
                        Content="Personal Details"
                        HorizontalAlignment="Center"
                        IsChecked="{Binding ActiveSection, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Details}"
                        VerticalAlignment="Center" />
                    <ToggleButton
                        Classes="Outline"
                        Command="{Binding ShowSecurityCommand}"
                        Content="Security"
                        HorizontalAlignment="Center"
                        IsChecked="{Binding ActiveSection, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Security}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <!--  ── Error banner ─────────────────────────────────────────────  -->
                <shadUi:Card Background="{DynamicResource DestructiveColor}" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock
                        Foreground="White"
                        Text="{Binding ErrorMessage}"
                        TextWrapping="Wrap" />
                </shadUi:Card>

                <!--
                    ══════════════════════════════════════════════════════════════
                    PERSONAL DETAILS SECTION
                    ══════════════════════════════════════════════════════════════
                -->
                <shadUi:Card HasShadow="True" IsVisible="{Binding ActiveSection, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Details}">
                    <StackPanel Spacing="14">

                        <!--  Card header with Edit / Cancel toggle  -->
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock
                                Classes="h3"
                                Grid.Column="0"
                                Text="Account Information" />

                        </Grid>

                        <Separator />

                        <!--  Full Name  -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <LucideIcon
                                Kind="SquareUser"
                                Size="20"
                                VerticalAlignment="Center" />
                            <!--  READ: plain text when not editing  -->
                            <TextBlock
                                Classes="Small"
                                IsVisible="{Binding !IsEditMode}"
                                Text="{Binding FullName}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center" />
                            <!--  EDIT: text input  -->
                            <TextBox
                                IsVisible="{Binding IsEditMode}"
                                Text="{Binding FullName}"
                                VerticalAlignment="Center"
                                Watermark="Enter your full name" />
                        </StackPanel>

                        <!--  Email (read-only — managed by Appwrite Auth)  -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon
                                    Kind="AtSign"
                                    Size="20"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Classes="Small"
                                    Text="{Binding Email}"
                                    VerticalAlignment="Center" />

                            </StackPanel>
                            <TextBlock
                                Classes="Muted"
                                FontSize="11"
                                IsVisible="{Binding IsEditMode}"
                                Text="Email is managed by your account and cannot be changed here."
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <!--  Phone (read-only — managed by Appwrite Auth)  -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <LucideIcon
                                    Kind="Smartphone"
                                    Size="20"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Phone}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock
                                Classes="Muted"
                                FontSize="11"
                                IsVisible="{Binding IsEditMode}"
                                Text="Phone is linked to your account and cannot be changed here."
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <!--  ID Number  -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <LucideIcon
                                Kind="IdCard"
                                Size="20"
                                VerticalAlignment="Center" />
                            <TextBlock
                                IsVisible="{Binding !IsEditMode}"
                                Text="{Binding IdNumber, FallbackValue='—'}"
                                VerticalAlignment="Center" />
                            <TextBox
                                IsVisible="{Binding IsEditMode}"
                                MaxLength="13"
                                Text="{Binding IdNumber}"
                                VerticalAlignment="Center"
                                Watermark="Enter your 13-digit ID number" />
                        </StackPanel>

                        <Separator />

                        <TextBlock Classes="h3" Text="Banking Details" />

                        <!--  Bank Name dropdown  -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <LucideIcon
                                Kind="Landmark"
                                Size="20"
                                VerticalAlignment="Center" />
                            <!--  READ  -->
                            <TextBlock
                                IsVisible="{Binding !IsEditMode}"
                                Text="{Binding SelectedBank.BankName, FallbackValue='—'}"
                                VerticalAlignment="Center" />
                            <!--  EDIT  -->
                            <ComboBox
                                DisplayMemberBinding="{Binding BankName}"
                                IsVisible="{Binding IsEditMode}"
                                ItemsSource="{Binding AvailableBanks}"
                                SelectedItem="{Binding SelectedBank}"
                                VerticalAlignment="Center"
                                Width="300" />
                        </StackPanel>

                        <!--  Branch Code (auto-filled from selection, read-only)  -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <LucideIcon
                                Kind="Split"
                                Size="20"
                                VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedBank.NationalBranchCode, FallbackValue='—'}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!--  Bank Account Number  -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <LucideIcon
                                Kind="CreditCard"
                                Size="20"
                                VerticalAlignment="Center" />
                            <TextBlock
                                IsVisible="{Binding !IsEditMode}"
                                Text="{Binding BankAccount, FallbackValue='—'}"
                                VerticalAlignment="Center" />
                            <TextBox
                                IsVisible="{Binding IsEditMode}"
                                Text="{Binding BankAccount}"
                                VerticalAlignment="Center"
                                Watermark="Enter your bank account number" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">

                            <!--  Cancel button — visible only in edit mode  -->
                            <Button
                                Classes="Outline"
                                Command="{Binding CancelEditCommand}"
                                Content="Cancel"
                                IsVisible="{Binding IsEditMode}" />

                            <!--  Save button — visible only in edit mode  -->
                            <Button
                                Classes="Primary"
                                Command="{Binding SaveProfileCommand}"
                                Content="Save Changes"
                                IsEnabled="{Binding !IsBusy}"
                                IsVisible="{Binding IsEditMode}"
                                shadUi:ButtonAssist.ShowProgress="{Binding IsBusy}" />

                            <!--  Edit button — visible when not in edit mode  -->
                            <Button
                                Classes="Outline"
                                Command="{Binding ToggleEditModeCommand}"
                                IsVisible="{Binding !IsEditMode}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <LucideIcon Kind="Pencil" Size="14" />
                                    <TextBlock Text="Edit" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </shadUi:Card>

                <!--
                    ══════════════════════════════════════════════════════════════
                    SECURITY SECTION – Change Password
                    ══════════════════════════════════════════════════════════════
                -->
                <shadUi:Card HasShadow="True" IsVisible="{Binding ActiveSection, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Security}">
                    <StackPanel Spacing="14">

                        <TextBlock Classes="h3" Text="Change Password" />
                        <Separator />

                        <!--  Current Password  -->
                        <TextBox
                            Classes="PasswordReveal"
                            PasswordChar="•"
                            Text="{Binding CurrentPassword, Mode=TwoWay}"
                            Watermark="Min 8 characters"
                            shadUi:ControlAssist.Label="Current Password" />

                        <!--  Password  -->
                        <TextBox
                            Classes="PasswordReveal"
                            PasswordChar="•"
                            Text="{Binding NewPassword, Mode=TwoWay}"
                            Watermark="Min 8 characters"
                            shadUi:ControlAssist.Label="Password" />

                        <!--  Confirm password  -->
                        <TextBox
                            Classes="PasswordReveal"
                            Margin="0,0,0,24"
                            PasswordChar="•"
                            Text="{Binding ConfirmPassword, Mode=TwoWay}"
                            Watermark="Confirm password"
                            shadUi:ControlAssist.Label="Confirm password" />

                        <Button
                            Classes="Primary"
                            Command="{Binding ChangePasswordCommand}"
                            Content="Update Password"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding !IsBusy}"
                            shadUi:ButtonAssist.ShowProgress="{Binding IsBusy}" />

                    </StackPanel>
                </shadUi:Card>

                <!--  ── Logout ────────────────────────────────────────────────────────  -->
                <!--  MOVED from DashboardViewModel — logout lives on the Profile tab.  -->
                <shadUi:Card HasShadow="True">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="h4" Text="Session" />
                        <Separator />
                        <TextBlock Classes="Muted" Text="Signing out will clear your cached session and return you to the login screen." />
                        <Button
                            Classes="Destructive"
                            Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding !IsBusy}"
                            shadUi:ButtonAssist.ShowProgress="{Binding IsBusy}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <LucideIcon Kind="LogOut" Size="14" />
                                <TextBlock Text="Sign Out" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </shadUi:Card>
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>
