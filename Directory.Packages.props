    <PackageVersion Include="Avalonia.iOS" Version="11.3.13" />
    <PackageVersion Include="Avalonia.Browser" Version="11.3.13" />
    <PackageVersion Include="Avalonia.Android" Version="11.3.13" />
    <PackageVersion Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageVersion Include="DialogHost.Avalonia" Version="0.11.0" />
    <PackageVersion Include="Jab" Version="0.12.0" />
    <PackageVersion Include="Lucide.Avalonia" Version="0.2.2" />
    <PackageVersion Include="Microsoft.Extensions.Configuration" Version="10.0.5" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.5" />
